# ═══════════════════════════════════════════════════════════════════════════════
# 🦍 HECTOR - Archivo de Configuración
# Sistema Central de Orquestación y Producción de Activos Digitales
# Ecosistema: Rodamaster 86
# Autorización: Agente 8686
# ═══════════════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────────────────────
# GOOGLE CLOUD CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────────

# Project ID en Google Cloud
GCP_PROJECT_ID=hector-production

# Ruta a archivo de credenciales de Service Account
GCP_CREDENTIALS_PATH=./config/hector-service-account.json

# Email del Service Account
GCP_SERVICE_ACCOUNT_EMAIL=hector-bot@hector-production.iam.gserviceaccount.com

# ────────────────────────────────────────────────────────────────────────────────
# GOOGLE SHEETS CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────────

# Nombre de la hoja de cálculo principal
GOOGLE_SHEETS_NAME=Registro de inversiones de Google Finance

# ID de la carpeta en Google Drive (opcional)
GOOGLE_DRIVE_FOLDER_ID=

# Nombre de la pestaña de datos financieros
SHEETS_WORKSHEET_NAME=Registro de inversiones

# Nombre de la pestaña de logs
SHEETS_LOG_WORKSHEET=Logs de Producción

# ────────────────────────────────────────────────────────────────────────────────
# HECTOR PRODUCTION CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────────

# Modo de operación: production, staging, development
ENVIRONMENT=production

# Modo de HECTOR: mass_production, standard, debug
HECTOR_MODE=mass_production

# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Número máximo de activos a procesar por ciclo
MAX_BATCH_SIZE=500

# Tamaño de lote por defecto
DEFAULT_BATCH_SIZE=100

# ────────────────────────────────────────────────────────────────────────────────
# FINANCIAL DATA TRACKING
# ────────────────────────────────────────────────────────────────────────────────

# Ticker de activo a trackear (ej: GOOGL para Alphabet Inc Class C)
TRACKING_TICKER=GOOGL

# Intervalo de sincronización en segundos (3600 = 1 hora)
TRACKING_INTERVAL=3600

# Símbolo de moneda
CURRENCY=USD

# ────────────────────────────────────────────────────────────────────────────────
# CONTENT GENERATION CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────────

# Canal de distribución principal (ej: sembradordesueños)
PRIMARY_CHANNEL=sembradordesueños

# Generar contenido educativo automáticamente
AUTO_GENERATE_CONTENT=true

# Idioma de generación de contenido
CONTENT_LANGUAGE=es

# ────────────────────────────────────────────────────────────────────────────────
# NOTIFICATIONS CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────────

# URL de Webhook de Discord (dejar vacío para desactivar)
DISCORD_WEBHOOK_URL=

# Token de Bot de Telegram
TELEGRAM_BOT_TOKEN=

# Chat ID de Telegram
TELEGRAM_CHAT_ID=

# Email para notificaciones críticas
NOTIFICATION_EMAIL=

# ────────────────────────────────────────────────────────────────────────────────
# SYSTEM AUTHORIZATION
# ────────────────────────────────────────────────────────────────────────────────

# Código de autorización del Agente 8686 (CRÍTICO - NO COMPARTIR)
# Formato: Números solamente
AGENT_AUTHORIZATION_CODE=8686

# ────────────────────────────────────────────────────────────────────────────────
# DATA PATHS
# ────────────────────────────────────────────────────────────────────────────────

# Directorio de datos
DATA_DIR=./data

# Directorio de logs
LOG_DIR=./logs

# Directorio de reportes
REPORTS_DIR=./reports

# ────────────────────────────────────────────────────────────────────────────────
# ADVANCED CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────────

# Habilitar caché local
ENABLE_CACHING=true

# Duración de caché en segundos (3600 = 1 hora)
CACHE_DURATION=3600

# Habilitar modo de prueba (no guarda datos)
TEST_MODE=false

# Timeout para requests en segundos
REQUEST_TIMEOUT=30

# ════════════════════════════════════════════════════════════════════════════════
# ⚠️  IMPORTANTE - SEGURIDAD
# ════════════════════════════════════════════════════════════════════════════════
# 
# 1. NUNCA subas este archivo con valores reales a Git
# 2. Usa .gitignore para excluir .env
# 3. Las credenciales NUNCA deben compartirse
# 4. Requiere autorización del Agente 8686 para cambios en producción
# 5. Revisa logs regularmente para detectar anomalías
#
# ════════════════════════════════════════════════════════════════════════════════
